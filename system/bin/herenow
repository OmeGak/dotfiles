#! /bin/bash
# Monitor the mouse position regularly

set -e
progname=$(basename "$0")

usage() {
  echo "usage: ${progname} [-f <num>] [-d <num>] [-h]"
  echo "  -f frequency  Set the monitoring frequency in seconds (default: 1)"
  echo "  -d duration   Number of minutes to monitor (must be > 0)"
  echo "  -h            Display this help message"
  exit 1
}

frequency=1  # Default monitoring frequency in seconds
duration_minutes=""  # Leave empty to run indefinitely; set with -d <minutes>

# Parse command line options
while getopts ":f:d:h" opt; do
  case ${opt} in
    f)
      frequency=${OPTARG}
      ;;
    d)
      duration_minutes=${OPTARG}
      ;;
    h)
      usage
      ;;
    \?)
      usage
      ;;
  esac
done

# Handle invalid arguments
shift $((OPTIND -1))
if [ $# -ne 0 ]; then
  usage
fi

# Validate and convert duration input, if provided
if [ -n "${duration_minutes}" ]; then
  if ! [[ ${duration_minutes} =~ ^[0-9]+$ ]]; then
    usage
  fi
  if [ "${duration_minutes}" -le 0 ]; then
    usage
  fi
  duration_seconds=$((duration_minutes * 60))
else
  duration_seconds=""
fi

capture_position() {
  local position raw_pos x y
  raw_pos=$(cliclick p)
  cliclick m:0,0 "m:${raw_pos}"

  IFS=',' read -r x y <<< "${raw_pos}"
  x=$(printf '%04d' "${x}")
  y=$(printf '%04d' "${y}")
  position="${x}, ${y}"

  echo "${position}"
}

format_elapsed() {
  local total_seconds=$1
  local minutes=$((total_seconds / 60))
  local seconds=$((total_seconds % 60))
  printf '%sm%02ds' "${minutes}" "${seconds}"
}

format_left_text() {
  local end=$1
  local now=$2

  if [ -z "${end}" ]; then
    echo ""
    return
  fi

  local remaining_seconds=$((end - now))
  if [ "${remaining_seconds}" -lt 0 ]; then
    remaining_seconds=0
  fi

  local remaining_formatted
  remaining_formatted=$(format_elapsed "${remaining_seconds}")
  printf ' \033[1mLEFT\033[0m: [-%s]' "${remaining_formatted}"
}

print_status() {
  local position=$1
  local elapsed=$2
  local left_segment=$3
  printf '\033[1mHERE\033[0m: (%s) \033[1mNOW\033[0m: [+%s]%s\n' "${position}" "${elapsed}" "${left_segment}"
}

should_stop_monitoring() {
  local end=$1
  local now=$2

  if [ -z "${end}" ]; then
    return 1
  fi

  if [ "${now}" -ge "${end}" ]; then
    return 0
  fi

  return 1
}

# Calculate start and end times
start_time=$(date +%s)
if [ -n "${duration_seconds}" ]; then
  end_time=$((start_time + duration_seconds))
else
  end_time=""
fi

# Mouse position monitoring loop
while true; do
  current_time=$(date +%s)
  elapsed_seconds=$((current_time - start_time))
  elapsed_time=$(format_elapsed "${elapsed_seconds}")
  position=$(capture_position)
  left_text=$(format_left_text "${end_time}" "${current_time}")
  print_status "${position}" "${elapsed_time}" "${left_text}"
  sleep "${frequency}"
  if should_stop_monitoring "${end_time}" "${current_time}"; then
    break
  fi
done
